# ============================================================
# WaAuto - WhatsApp Automation SaaS Platform
# Environment Variables Template
# Copy this file to .env and fill in your actual values
# ============================================================

# ============================================================
# Server Configuration
# ============================================================
PORT=5000
NODE_ENV=development
APP_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================
# Database Configuration
# ============================================================
# MongoDB URI - Replace with your actual MongoDB connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/databasename
# Local: mongodb://localhost:27017/waauto
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/waauto

# ============================================================
# JWT Authentication
# ============================================================
# Generate a strong random string for JWT_SECRET
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
TOKEN_ENCRYPTION_KEY=generate-a-separate-32-byte-random-secret

# ============================================================
# WhatsApp Integration (Meta Cloud API)
# ============================================================
# Create these in Meta Business / WhatsApp Manager
META_GRAPH_API_VERSION=v22.0
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_CONFIG_ID=your_embedded_signup_config_id
META_VERIFY_TOKEN=your_webhook_verify_token
META_SYSTEM_USER_ACCESS_TOKEN=your_system_user_or_business_access_token
META_PHONE_NUMBER_ID=your_cloud_api_phone_number_id
META_WABA_ID=your_whatsapp_business_account_id

# Legacy GupShup fallback, optional
GUPSHUP_BASE_URL=https://api.gupshup.io

# Your GupShup API key (available in API Keys section)
# Get from: Dashboard → Settings → API Keys → Copy API Key
GUPSHUP_API_KEY=your_gupshup_api_key_here

# Your GupShup app name
# Get from: Dashboard → Apps → Copy your app name
GUPSHUP_APP_NAME=your_gupshup_app_name_here

# Webhook URL for incoming messages from GupShup
# This URL should be publicly accessible for production
# Local development: http://localhost:5000/api/webhook/whatsapp
# Production: https://your-domain.com/api/webhook/whatsapp
GUPSHUP_ONBOARDING_URL=http://localhost:5000/api/webhook/whatsapp

# Webhook secret for GupShup verification
# Optional but recommended for security
# Get from GupShup dashboard if you set up webhooks
GUPSHUP_ONBOARDING_SECRET=your_gupshup_webhook_secret_here

# Production sending controls
WHATSAPP_SEND_ENABLED=true
BROADCAST_ALLOW_FREEFORM=false
SUBSCRIPTION_ENABLED=false

# ============================================================
# Razorpay Payment Integration
# ============================================================
# Get these from https://dashboard.razorpay.com
# 1. Sign up for Razorpay account
# 2. Complete verification
# 3. Get test/live keys from Settings

# Razorpay Key ID (test or live)
# Get from: Dashboard → Settings → API Keys → Key ID
# Test Key: rzp_test_...
# Live Key: rzp_live_... (only after verification)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXXXX

# Razorpay Key Secret (test or live)
# Get from: Dashboard → Settings → API Keys → Key Secret
# Keep this secret! Never commit to version control
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXX

# ============================================================
# Email Configuration (Optional - for future use)
# ============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@waauto.com

# ============================================================
# AWS S3 Configuration (Optional - for future use)
# ============================================================
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ============================================================
# Third-party Services (Optional)
# ============================================================
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================================
# Feature Flags (Optional)
# ============================================================
# ENABLE_CHATBOT=true
# ENABLE_BROADCASTS=true
# ENABLE_ANALYTICS=true
# MAINTENANCE_MODE=false

# ============================================================
# Important Notes
# ============================================================
# 1. Never commit this file to version control (add to .gitignore)
# 2. Use different values for development and production
# 3. Rotate secrets regularly
# 4. For production, use strong JWT_SECRET and RAZORPAY_KEY_SECRET
# 5. GupShup webhook URL must be publicly accessible
# 6. Test all integrations before going live

# ============================================================
# Common Issues & Solutions
# ============================================================
# Issue: MONGODB_URI connection error
# Solution: Check connection string format and IP whitelist in MongoDB Atlas

# Issue: GupShup messages not sending
# Solution: Verify API key, app name, and webhook URL are correct

# Issue: Razorpay payment fails
# Solution: Use test keys for development, live keys for production

# Issue: JWT auth failing
# Solution: Ensure JWT_SECRET is consistent across all deployments

# For more help, see QUICK_START.md and README.md
